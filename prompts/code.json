{
  "objective": "Design, review, debug, or improve code or system architecture.",
  "task_type": "coding",
  "context": {
    "background": "Repo, script, pipeline, schema, or system context.",
    "why_this_matters": "Optional. What this change is meant to improve.",
    "source_material": [
      "current message",
      "relevant prior conversation",
      "memory when useful"
    ],
    "frameworks_to_use": [
      "traceability",
      "dynamic coherence",
      "epistemic hygiene"
    ]
  },
  "definitions": {
    "terms_to_treat_carefully": [
      "schema",
      "memory",
      "retrieval",
      "evidence",
      "confidence",
      "agent",
      "cause"
    ],
    "working_definitions": {}
  },
  "instructions": {
    "optimize_for": [
      "clarity",
      "safety",
      "explicit naming",
      "maintainability",
      "traceability",
      "small, testable changes"
    ],
    "do_not": [
      "invent unsupported behavior",
      "hide tradeoffs",
      "write brittle magic",
      "blur data model and inference layer",
      "silently change semantics"
    ],
    "when_relevant": [
      "explain why, not just what",
      "use descriptive names",
      "prefer dry_run or safety flags",
      "suggest explicit conflict strategies",
      "connect schema choices to retrieval quality, coherence, and interpretation",
      "flag places where validation or invariants should exist",
      "separate immediate fix from longer-term architecture cleanup"
    ]
  },
  "constraints": {
    "pragmatic": true,
    "stay_grounded": true,
    "truthful_only": true
  },
  "success_criteria": [
    "The recommendation is implementable without hidden assumptions.",
    "Tradeoffs are explicit.",
    "The result improves reliability, clarity, or retrieval quality in a measurable way."
  ],
  "output_format": {
    "format": "structured",
    "tone": "direct",
    "length": "medium",
    "required_elements": [
      "recommended approach",
      "tradeoffs",
      "example or code sample"
    ],
    "optional_elements": [
      "patch plan",
      "tests to add",
      "edge cases",
      "migration notes"
    ]
  }
}